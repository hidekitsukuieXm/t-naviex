enum BugCountermeasureCategory {
  PREVENTION      // 予防策
  DETECTION       // 検出策
  CORRECTION      // 修正策
  ROOT_CAUSE      // 根本原因対策
  PROCESS         // プロセス改善
  TOOL            // ツール活用
  OTHER           // その他

  @@map("bug_countermeasure_category")
}

/// バグ対策ナレッジステータス
enum BugCountermeasureStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED

  @@map("bug_countermeasure_status")
}

