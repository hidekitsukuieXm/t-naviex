  columnIndex     Int             @map("column_index")
  generatedTestCaseId BigInt?     @map("generated_test_case_id")
  generatedTitle  String          @map("generated_title") @db.VarChar(500)
  generatedSteps  Json?           @map("generated_steps") @db.JsonB
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  matrixTestCase  MatrixTestCase  @relation(fields: [matrixTestCaseId], references: [id], onDelete: Cascade)

  @@unique([matrixTestCaseId, rowIndex, columnIndex])
  @@index([matrixTestCaseId])
  @@index([generatedTestCaseId])
  @@map("matrix_expanded_cases")
}

// ========================================
// 状態遷移・画面遷移関連
// ========================================

/// 遷移図タイプ
enum DiagramType {
  STATE_TRANSITION  @map("state_transition")
  SCREEN_TRANSITION @map("screen_transition")
}

/// ノードタイプ
enum TransitionNodeType {
  STATE    @map("state")
  SCREEN   @map("screen")
  START    @map("start")
  END      @map("end")
  DECISION @map("decision")
  FORK     @map("fork")
  JOIN     @map("join")
}

/// カバレッジタイプ
enum CoverageType {
  NODE       @map("node")
  EDGE       @map("edge")
  EDGE_PAIR  @map("edge_pair")
  PATH       @map("path")
  PRIME_PATH @map("prime_path")
}

/// 遷移図
model TransitionDiagram {
  id          BigInt       @id @default(autoincrement())
  projectId   BigInt       @map("project_id")
  testCaseId  BigInt?      @map("test_case_id")
  name        String       @db.VarChar(255)
  description String?      @db.Text
  type        DiagramType
  nodes       Json         @db.JsonB // TransitionNode[]
  edges       Json         @db.JsonB // TransitionEdge[]
  metadata    Json?        @db.JsonB // DiagramMetadata
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCase        TestCase?         @relation(fields: [testCaseId], references: [id], onDelete: SetNull)
  generatedPaths  TransitionPath[]
  coverageAnalyses CoverageAnalysis[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([testCaseId])
  @@index([type])
  @@index([isActive])
  @@map("transition_diagrams")
}

/// 遷移パス
model TransitionPath {
  id          BigInt              @id @default(autoincrement())
  diagramId   BigInt              @map("diagram_id")
  name        String              @db.VarChar(255)
  description String?             @db.Text
  nodeIds     Json                @map("node_ids") @db.JsonB // string[]
  edgeIds     Json                @map("edge_ids") @db.JsonB // string[]
  pathLength  Int                 @map("path_length")
  pathType    String              @map("path_type") @db.VarChar(50)
  isLoop      Boolean             @default(false) @map("is_loop")
  coverage    Json?               @db.JsonB // PathCoverage
  generatedTestCaseId BigInt?     @map("generated_test_case_id")
  createdAt   DateTime            @default(now()) @map("created_at")

  // Relations
  diagram TransitionDiagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@index([diagramId])
  @@index([pathType])
  @@index([generatedTestCaseId])
  @@map("transition_paths")
}

/// カバレッジ分析
model CoverageAnalysis {
  id                  BigInt       @id @default(autoincrement())
  diagramId           BigInt       @map("diagram_id")
  coverageType        CoverageType @map("coverage_type")
  totalItems          Int          @map("total_items")
  coveredItems        Int          @map("covered_items")
  coveragePercentage  Float        @map("coverage_percentage")
  items               Json         @db.JsonB // CoverageItem[]
  testCaseMapping     Json         @map("test_case_mapping") @db.JsonB // TestCaseCoverageMapping[]
  createdAt           DateTime     @default(now()) @map("created_at")

  // Relations
  diagram TransitionDiagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@index([diagramId])
  @@index([coverageType])
  @@map("coverage_analyses")
}

// ========================================
// 組合せテスト支援（Issue #139）
// ========================================

/// 組合せテスト手法
enum CombinatorialMethod {
  PAIRWISE         @map("pairwise")
  ALL_COMBINATIONS @map("all_combinations")
  ORTHOGONAL_ARRAY @map("orthogonal_array")
  N_WISE           @map("n_wise")
}

/// 組合せテスト定義
model CombinatorialDefinition {
  id          BigInt              @id @default(autoincrement())
  projectId   BigInt              @map("project_id")
  testCaseId  BigInt?             @map("test_case_id")
  name        String              @db.VarChar(200)
  description String?             @db.Text
  method      CombinatorialMethod
  nWiseLevel  Int?                @map("n_wise_level")
  parameters  Json                @db.JsonB // CombinatorialParameter[]
  constraints Json?               @db.JsonB // Constraint[]
  metadata    Json?               @db.JsonB // CombinatorialMetadata
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  // Relations
  project  Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCase TestCase?             @relation(fields: [testCaseId], references: [id], onDelete: SetNull)
  result   CombinatorialResult?

  @@unique([projectId, name])
  @@index([projectId])
  @@index([testCaseId])
  @@index([method])
  @@index([isActive])
  @@map("combinatorial_definitions")
}

/// 組合せテスト生成結果
model CombinatorialResult {
  id           BigInt              @id @default(autoincrement())
  definitionId BigInt              @unique @map("definition_id")
  method       CombinatorialMethod
  combinations Json                @db.JsonB // Combination[]
  coverage     Json                @db.JsonB // CoverageSummary
  statistics   Json                @db.JsonB // GenerationStatistics
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  // Relations
  definition CombinatorialDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([method])
  @@map("combinatorial_results")
}

// ========================================
// スマートテスト選択（Issue #140）
// ========================================

/// 変更スコープ
enum ImpactScopeEnum {
  SINGLE_FEATURE   @map("single_feature")
  MULTIPLE_FEATURES @map("multiple_features")
  MODULE           @map("module")
  SYSTEM_WIDE      @map("system_wide")
}

/// 変更セット
model ChangeSet {
  id          String          @id @default(uuid()) @db.Uuid
  projectId   BigInt          @map("project_id")
  name        String          @db.VarChar(200)
  description String?         @db.Text
  changes     Json            @db.JsonB // ChangeItem[]
  scope       String          @default("SINGLE_FEATURE") @db.VarChar(50)
  metadata    Json?           @db.JsonB
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  impactAnalyses    ImpactAnalysis[]
  recommendedSets   RecommendedTestSet[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([createdAt])
  @@map("change_sets")
}

/// 影響分析結果
model ImpactAnalysis {
  id                   String   @id @default(uuid()) @db.Uuid
  changeSetId          String   @map("change_set_id") @db.Uuid
  analyzedAt           DateTime @default(now()) @map("analyzed_at")
  affectedModules      Json     @db.JsonB // AffectedModule[]
  affectedFeatures     Json     @db.JsonB // AffectedFeature[]
  affectedRequirements Json     @db.JsonB // AffectedRequirement[]
  riskScore            Int      @map("risk_score")
  summary              String   @db.Text

  // Relations
  changeSet ChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@index([changeSetId])
  @@index([analyzedAt])
  @@map("impact_analyses")
}

/// 推奨テストセット
model RecommendedTestSet {
  id                     String   @id @default(uuid()) @db.Uuid
  projectId              BigInt   @map("project_id")
  name                   String   @db.VarChar(200)
  description            String?  @db.Text
  changeSetId            String   @map("change_set_id") @db.Uuid
  analysisId             String   @map("analysis_id") @db.VarChar(100)
  selections             Json     @db.JsonB // TestCaseSelection[]
  totalTestCases         Int      @map("total_test_cases")
  estimatedTotalDuration Int      @map("estimated_total_duration")
  coveragePercentage     Int      @map("coverage_percentage")
  riskCoverage           Int      @map("risk_coverage")
  createdAt              DateTime @default(now()) @map("created_at")

  // Relations
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeSet ChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([changeSetId])
  @@index([createdAt])
  @@map("recommended_test_sets")
}

// ========================================
// ブランチ管理（Issue #141）
// ========================================

/// ブランチステータス
enum TestSpecBranchStatus {
  ACTIVE  @map("active")
  MERGED  @map("merged")
  DELETED @map("deleted")
  FROZEN  @map("frozen")
}

/// ブランチタイプ
enum TestSpecBranchType {
  MASTER       @map("master")
  FEATURE      @map("feature")
  RELEASE      @map("release")
  HOTFIX       @map("hotfix")
  EXPERIMENTAL @map("experimental")
}

/// マージステータス
enum MergeRequestStatus {
  PENDING     @map("pending")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CONFLICT    @map("conflict")
  CANCELLED   @map("cancelled")
}

/// テスト仕様書ブランチ
model TestSpecBranch {
  id             String               @id @default(uuid()) @db.Uuid
  testSpecId     BigInt               @map("test_spec_id")
  name           String               @db.VarChar(100)
  description    String?              @db.Text
  type           TestSpecBranchType   @default(FEATURE)
  status         TestSpecBranchStatus @default(ACTIVE)
  parentBranchId String?              @map("parent_branch_id") @db.Uuid
  createdBy      BigInt               @map("created_by")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  metadata       Json?                @db.JsonB

  // Relations
  testSpec          TestSpec           @relation(fields: [testSpecId], references: [id], onDelete: Cascade)
  parentBranch      TestSpecBranch?    @relation("BranchHierarchy", fields: [parentBranchId], references: [id], onDelete: SetNull)
  childBranches     TestSpecBranch[]   @relation("BranchHierarchy")
  snapshots         BranchSnapshot[]
  sourceMerges      MergeRequest[]     @relation("SourceBranch")
  targetMerges      MergeRequest[]     @relation("TargetBranch")
  histories         BranchHistory[]

  @@unique([testSpecId, name])
  @@index([testSpecId])
  @@index([status])
  @@index([type])
  @@index([parentBranchId])
  @@map("test_spec_branches")
}

/// ブランチスナップショット
model BranchSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  version       Int
  commitMessage String   @map("commit_message") @db.VarChar(500)
  testCases     Json     @db.JsonB // TestCaseSnapshot[]
  createdBy     BigInt   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  metadata      Json?    @db.JsonB

  // Relations
  branch TestSpecBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, version])
  @@index([branchId])
  @@index([createdAt])
  @@map("branch_snapshots")
}

/// マージリクエスト
model MergeRequest {
  id             String             @id @default(uuid()) @db.Uuid
  testSpecId     BigInt             @map("test_spec_id")
  sourceBranchId String             @map("source_branch_id") @db.Uuid
  targetBranchId String             @map("target_branch_id") @db.Uuid
  title          String             @db.VarChar(200)
  description    String?            @db.Text
  status         MergeRequestStatus @default(PENDING)
  conflicts      Json?              @db.JsonB // MergeConflict[]
  createdBy      BigInt             @map("created_by")
  createdAt      DateTime           @default(now()) @map("created_at")
  mergedAt       DateTime?          @map("merged_at")
  mergedBy       BigInt?            @map("merged_by")
  metadata       Json?              @db.JsonB

  // Relations
  testSpec     TestSpec       @relation(fields: [testSpecId], references: [id], onDelete: Cascade)
  sourceBranch TestSpecBranch @relation("SourceBranch", fields: [sourceBranchId], references: [id], onDelete: Cascade)
  targetBranch TestSpecBranch @relation("TargetBranch", fields: [targetBranchId], references: [id], onDelete: Cascade)

  @@index([testSpecId])
  @@index([sourceBranchId])
  @@index([targetBranchId])
  @@index([status])
  @@index([createdAt])
  @@map("merge_requests")
}

/// ブランチ履歴
model BranchHistory {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   BigInt   @map("project_id")
  branchId    String   @map("branch_id") @db.Uuid
  action      String   @db.VarChar(50)
  description String   @db.VarChar(500)
  userId      BigInt   @map("user_id")
  timestamp   DateTime @default(now())
  metadata    Json?    @db.JsonB

  // Relations
  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branch  TestSpecBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([branchId])
  @@index([timestamp])
  @@map("branch_histories")
}
