// ============================================
// カスタムフィールドモデル
// ============================================

/// カスタムフィールドタイプ
enum CustomFieldType {
  TEXT           // テキスト
  NUMBER         // 数値
  DATE           // 日付
  SELECT_SINGLE  // 単一選択
  SELECT_MULTI   // 複数選択
  CHECKBOX       // チェックボックス
  URL            // URL
  EMAIL          // メールアドレス

  @@map("custom_field_type")
}

/// カスタムフィールド対象エンティティ
enum CustomFieldTargetEntity {
  TEST_CASE    // テストケース
  BUG          // バグ
  TEST_SPEC    // テスト仕様書
  TEST_RESULT  // テスト結果
  TEST_RUN     // テスト実行

  @@map("custom_field_target_entity")
}

/// カスタムフィールド定義
model CustomFieldDefinition {
  id                BigInt                  @id @default(autoincrement())
  projectId         BigInt                  @map("project_id")
  name              String                  @db.VarChar(100) // 内部名（英数字）
  displayName       String                  @map("display_name") @db.VarChar(255) // 表示名
  description       String?                 @db.Text
  fieldType         CustomFieldType         @map("field_type")
  targetEntity      CustomFieldTargetEntity @map("target_entity")
  isRequired        Boolean                 @default(false) @map("is_required")
  isSearchable      Boolean                 @default(true) @map("is_searchable") // 検索可能か
  isFilterable      Boolean                 @default(true) @map("is_filterable") // フィルター可能か
  isVisibleInList   Boolean                 @default(true) @map("is_visible_in_list") // 一覧表示するか
  sortOrder         Int                     @default(0) @map("sort_order")
  defaultValue      String?                 @map("default_value") @db.Text // デフォルト値（JSON形式）
  options           Json?                   @db.JsonB // 選択肢（SELECT_SINGLE, SELECT_MULTI用）
  validationRules   Json?                   @map("validation_rules") @db.JsonB // バリデーションルール
  metadata          Json?                   @db.JsonB // その他メタデータ
  isActive          Boolean                 @default(true) @map("is_active")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  // Relations
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values            CustomFieldValue[]

  @@unique([projectId, name, targetEntity])
  @@index([projectId])
  @@index([targetEntity])
  @@index([fieldType])
  @@index([isActive])
  @@index([sortOrder])
  @@map("custom_field_definitions")
}

/// カスタムフィールド値
model CustomFieldValue {
  id                BigInt                @id @default(autoincrement())
  definitionId      BigInt                @map("definition_id")
  entityId          BigInt                @map("entity_id") // 対象エンティティのID
  entityType        CustomFieldTargetEntity @map("entity_type") // 対象エンティティタイプ
  textValue         String?               @map("text_value") @db.Text // テキスト値
  numberValue       Decimal?              @map("number_value") @db.Decimal(20, 6) // 数値
  dateValue         DateTime?             @map("date_value") // 日付値
  booleanValue      Boolean?              @map("boolean_value") // チェックボックス値
  jsonValue         Json?                 @map("json_value") @db.JsonB // JSON値（複数選択など）
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  // Relations
  definition        CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([definitionId, entityId, entityType])
  @@index([definitionId])
  @@index([entityId, entityType])
  @@index([textValue])
  @@index([numberValue])
  @@index([dateValue])
  @@index([booleanValue])
  @@map("custom_field_values")
}

// ============================================
// BDD/Gherkin関連モデル
// ============================================

/// Gherkinステップタイプ
enum GherkinStepType {
  GIVEN
  WHEN
  THEN
  AND
  BUT

  @@map("gherkin_step_type")
}

/// Gherkin言語
enum GherkinLanguage {
  EN
  JA

  @@map("gherkin_language")
}

/// ステップ定義（ステップライブラリ）
model StepDefinition {
  id            BigInt          @id @default(autoincrement())
  projectId     BigInt          @map("project_id")
  type          GherkinStepType
  pattern       String          @db.Text // パターン（正規表現可）
  displayText   String          @map("display_text") @db.VarChar(500) // 表示用テキスト
  description   String?         @db.Text
  parameters    Json?           @db.JsonB // パラメータ定義
  isShared      Boolean         @default(false) @map("is_shared") // 他プロジェクトと共有可能か
  usageCount    Int             @default(0) @map("usage_count") // 使用回数
  lastUsedAt    DateTime?       @map("last_used_at")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
  @@index([isShared])
  @@index([usageCount])
  @@index([isActive])
  @@map("step_definitions")
}

/// BDDテストケース
model BddTestCase {
  id            BigInt          @id @default(autoincrement())
  testCaseId    BigInt          @unique @map("test_case_id")
  gherkinText   String          @map("gherkin_text") @db.Text // Gherkin記法のテキスト
  parsedFeature Json?           @map("parsed_feature") @db.JsonB // パース済みのFeature構造
  language      GherkinLanguage @default(JA)
  isValid       Boolean         @default(true) @map("is_valid") // パースが成功したか
  parseErrors   Json?           @map("parse_errors") @db.JsonB // パースエラー
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  testCase      TestCase        @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@index([testCaseId])
  @@index([language])
  @@index([isValid])
  @@map("bdd_test_cases")
}

