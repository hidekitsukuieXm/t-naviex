/// カタログアイテムステータス
enum CatalogItemStatus {
  DRAFT              // 下書き
  ACTIVE             // 有効
  DEPRECATED         // 非推奨
  ARCHIVED           // アーカイブ

  @@map("catalog_item_status")
}

/// カタログアイテム（再利用可能なテスト資産）
model CatalogItem {
  id            BigInt            @id @default(autoincrement())
  projectId     BigInt            @map("project_id")
  name          String            @db.VarChar(255)
