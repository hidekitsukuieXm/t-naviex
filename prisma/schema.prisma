/// 外部連携ステータスマッピング
model IntegrationStatusMapping {
  id                   BigInt              @id @default(autoincrement())
  integrationId        BigInt              @map("integration_id")
  localStatusId        BigInt              @map("local_status_id")
  externalStatusId     String              @map("external_status_id") @db.VarChar(100)
  externalStatusName   String              @map("external_status_name") @db.VarChar(100)
  syncDirection        SyncDirection       @map("sync_direction")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  // Relations
  integration ExternalIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  localStatus BugStatusMaster     @relation(fields: [localStatusId], references: [id], onDelete: Cascade)

  @@unique([integrationId, localStatusId])
  @@unique([integrationId, externalStatusId])
  @@index([integrationId])
  @@map("integration_status_mappings")
}

/// 同期方向
enum SyncDirection {
  BIDIRECTIONAL
  TO_EXTERNAL
  FROM_EXTERNAL

  @@map("sync_direction")
}

/// バグ同期履歴
model BugSync {
  id                BigInt     @id @default(autoincrement())
  bugId             BigInt     @map("bug_id")
  integrationId     BigInt     @map("integration_id")
  externalIssueId   String     @map("external_issue_id") @db.VarChar(100)
  externalIssueKey  String?    @map("external_issue_key") @db.VarChar(100)
  externalIssueUrl  String?    @map("external_issue_url") @db.VarChar(500)
  syncStatus        SyncStatus @map("sync_status")
  lastSyncAt        DateTime   @map("last_sync_at")
  lastSyncDirection SyncDirection @map("last_sync_direction")
  lastSyncError     String?    @map("last_sync_error") @db.VarChar(500)
  localUpdatedAt    DateTime   @map("local_updated_at")
  externalUpdatedAt DateTime?  @map("external_updated_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  // Relations
  bug         Bug                 @relation(fields: [bugId], references: [id], onDelete: Cascade)
  integration ExternalIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([bugId, integrationId])
  @@unique([integrationId, externalIssueId])
  @@index([bugId])
  @@index([integrationId])
  @@index([syncStatus])
  @@map("bug_syncs")
}

/// 同期ステータス
enum SyncStatus {
  SYNCED
  PENDING
  ERROR
  CONFLICT

  @@map("sync_status")
}

// ============================================
// 要求仕様管理
// ============================================

/// 要求仕様タイプ
enum RequirementType {
  FUNCTIONAL        // 機能要求
  NON_FUNCTIONAL    // 非機能要求
  CONSTRAINT        // 制約
  INTERFACE         // インターフェース
  DESIGN            // 設計
  USER_STORY        // ユーザーストーリー

  @@map("requirement_type")
}

/// 要求仕様ステータス
enum RequirementStatus {
  DRAFT             // 下書き
  PROPOSED          // 提案中
  APPROVED          // 承認済み
  IMPLEMENTED       // 実装済み
  VERIFIED          // 検証済み
  DEPRECATED        // 非推奨

  @@map("requirement_status")
}

/// 要求仕様優先度
enum RequirementPriority {
  MUST_HAVE         // 必須
  SHOULD_HAVE       // 重要
  COULD_HAVE        // あれば良い
  WONT_HAVE         // 今回は対象外

  @@map("requirement_priority")
}

/// 要求仕様
model Requirement {
  id              BigInt              @id @default(autoincrement())
  projectId       BigInt              @map("project_id")
  parentId        BigInt?             @map("parent_id")
  code            String              @db.VarChar(50)
  title           String              @db.VarChar(500)
  description     String?             @db.Text
  content         String?             @db.Text  // Markdown content
  type            RequirementType     @default(FUNCTIONAL)
  status          RequirementStatus   @default(DRAFT)
  priority        RequirementPriority @default(SHOULD_HAVE)
  version         String?             @db.VarChar(50)
  source          String?             @db.VarChar(500)  // 要求元（顧客名、文書名等）
  rationale       String?             @db.Text          // 根拠・理由
  acceptance      String?             @db.Text          // 受け入れ条件
  sortOrder       Int                 @default(0) @map("sort_order")
  createdById     BigInt              @map("created_by_id")
  updatedById     BigInt?             @map("updated_by_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  // Relations
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent          Requirement?        @relation("RequirementHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Requirement[]       @relation("RequirementHierarchy")
  createdBy       User                @relation("RequirementCreator", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy       User?               @relation("RequirementUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  testCases       TestCaseRequirement[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([parentId])
  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([sortOrder])
  @@map("requirements")
}

/// テストケースと要求仕様の関連（多対多）
model TestCaseRequirement {
  testCaseId      BigInt      @map("test_case_id")
  requirementId   BigInt      @map("requirement_id")
  createdAt       DateTime    @default(now()) @map("created_at")

  // Relations
  testCase        TestCase    @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  requirement     Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@id([testCaseId, requirementId])
  @@index([testCaseId])
  @@index([requirementId])
  @@map("test_case_requirements")
}

