// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ユーザー・権限系モデル
// ============================================

/// ユーザー
model User {
  id            BigInt     @id @default(autoincrement())
  email         String     @unique @db.VarChar(255)
  name          String     @db.VarChar(255)
  passwordHash  String?    @map("password_hash") @db.VarChar(255)
  emailVerified DateTime?  @map("email_verified")
  image         String?    @db.VarChar(500)
  status        UserStatus @default(ACTIVE)
  mfaEnabled    Boolean    @default(false) @map("mfa_enabled")
  mfaType       String?    @map("mfa_type") @db.VarChar(50)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relations
  accounts          Account[]
  sessions          Session[]
  userGroups        UserGroup[]
  projectMembers    ProjectMember[]
  auditLogs         AuditLog[]
  accountLockout    AccountLockout?
  passwordHistories PasswordHistory[]

  @@map("users")
}

/// ユーザーステータス
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING

  @@map("user_status")
}

/// NextAuth Account（OAuth連携用）
model Account {
  id                BigInt  @id @default(autoincrement())
  userId            BigInt  @map("user_id")
  type              String  @db.VarChar(255)
  provider          String  @db.VarChar(255)
  providerAccountId String  @map("provider_account_id") @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(255)
  scope             String? @db.VarChar(255)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// NextAuth Session
model Session {
  id           BigInt   @id @default(autoincrement())
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       BigInt   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// NextAuth VerificationToken（メール認証用）
model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// パスワードリセットトークン
model PasswordResetToken {
  id        BigInt   @id @default(autoincrement())
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

/// グループ
model Group {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userGroups UserGroup[]

  @@map("groups")
}

/// ユーザーグループ中間テーブル
model UserGroup {
  userId    BigInt   @map("user_id")
  groupId   BigInt   @map("group_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_groups")
}

/// ロール（権限定義）
model Role {
  id           BigInt   @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  displayName  String   @map("display_name") @db.VarChar(100)
  description  String?  @db.VarChar(500)
  permissions  Json     @default("{}") @db.JsonB
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  projectMembers ProjectMember[]

  @@map("roles")
}

// ============================================
// プロジェクト系モデル
// ============================================

/// プロジェクト
model Project {
  id            BigInt        @id @default(autoincrement())
  name          String        @db.VarChar(255)
  description   String?       @db.Text
  status        ProjectStatus @default(ACTIVE)
  projectType   String?       @map("project_type") @db.VarChar(100)
  targetVersion String?       @map("target_version") @db.VarChar(100)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  projectMembers ProjectMember[]
  testSpecs      TestSpec[]

  @@map("projects")
}

/// プロジェクトステータス
enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  PLANNING

  @@map("project_status")
}

/// プロジェクトメンバー中間テーブル
model ProjectMember {
  projectId BigInt   @map("project_id")
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([projectId, userId])
  @@map("project_members")
}

// ============================================
// 監査ログモデル
// ============================================

/// 監査ログ
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt?  @map("user_id")
  action     String   @db.VarChar(100)
  targetType String   @map("target_type") @db.VarChar(100)
  targetId   BigInt?  @map("target_id")
  details    Json?    @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// パスワードポリシー・セキュリティ系モデル
// ============================================

/// パスワードポリシー設定（シングルトン：1レコードのみ）
model PasswordPolicy {
  id                     BigInt   @id @default(autoincrement())
  minLength              Int      @default(8) @map("min_length")
  maxLength              Int      @default(100) @map("max_length")
  requireUppercase       Boolean  @default(true) @map("require_uppercase")
  requireLowercase       Boolean  @default(true) @map("require_lowercase")
  requireNumbers         Boolean  @default(true) @map("require_numbers")
  requireSpecialChars    Boolean  @default(false) @map("require_special_chars")
  expirationDays         Int      @default(0) @map("expiration_days")
  preventReuse           Int      @default(0) @map("prevent_reuse")
  maxLoginAttempts       Int      @default(5) @map("max_login_attempts")
  lockoutDurationMinutes Int      @default(30) @map("lockout_duration_minutes")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("password_policies")
}

/// アカウントロック情報
model AccountLockout {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @unique @map("user_id")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lastFailedAt   DateTime? @map("last_failed_at")
  lockedUntil    DateTime? @map("locked_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account_lockouts")
}

/// パスワード履歴（再利用防止用）
model PasswordHistory {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_histories")
}

/// セッション設定（シングルトン：1レコードのみ）
model SessionSettings {
  id                    BigInt   @id @default(autoincrement())
  sessionTimeoutMinutes Int      @default(30) @map("session_timeout_minutes")
  warningBeforeMinutes  Int      @default(5) @map("warning_before_minutes")
  extendOnActivity      Boolean  @default(true) @map("extend_on_activity")
  maxConcurrentSessions Int      @default(0) @map("max_concurrent_sessions")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("session_settings")
}

// ============================================
// テスト仕様書系モデル
// ============================================

/// テスト仕様書ステータス
enum TestSpecStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED

  @@map("test_spec_status")
}

/// テスト仕様書
model TestSpec {
  id          BigInt         @id @default(autoincrement())
  projectId   BigInt         @map("project_id")
  name        String         @db.VarChar(255)
  description String?        @db.Text
  status      TestSpecStatus @default(DRAFT)
  version     String         @default("1.0.0") @db.VarChar(50)
  isLocked    Boolean        @default(false) @map("is_locked")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions  TestSpecVersion[]
  sections  TestSection[]
  testCases TestCase[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("test_specs")
}

/// テスト仕様書バージョン履歴
model TestSpecVersion {
  id         BigInt   @id @default(autoincrement())
  testSpecId BigInt   @map("test_spec_id")
  version    String   @db.VarChar(50)
  changeNote String?  @map("change_note") @db.Text
  createdBy  BigInt?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  testSpec TestSpec @relation(fields: [testSpecId], references: [id], onDelete: Cascade)

  @@index([testSpecId])
  @@index([createdAt])
  @@map("test_spec_versions")
}

/// テストセクション（階層構造対応）
model TestSection {
  id         BigInt   @id @default(autoincrement())
  testSpecId BigInt   @map("test_spec_id")
  parentId   BigInt?  @map("parent_id")
  name       String   @db.VarChar(255)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  testSpec  TestSpec      @relation(fields: [testSpecId], references: [id], onDelete: Cascade)
  parent    TestSection?  @relation("SectionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  TestSection[] @relation("SectionHierarchy")
  testCases TestCase[]

  @@index([testSpecId])
  @@index([parentId])
  @@index([sortOrder])
  @@map("test_sections")
}

/// テストケース優先度
enum TestCasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW

  @@map("test_case_priority")
}

/// テストタイプ
enum TestType {
  FUNCTIONAL
  INTEGRATION
  E2E
  PERFORMANCE
  SECURITY
  USABILITY
  OTHER

  @@map("test_type")
}

/// テスト技法
enum TestTechnique {
  EQUIVALENCE_PARTITIONING
  BOUNDARY_VALUE_ANALYSIS
  DECISION_TABLE
  STATE_TRANSITION
  EXPLORATORY
  REGRESSION
  OTHER

  @@map("test_technique")
}

/// テストケース
model TestCase {
  id              BigInt           @id @default(autoincrement())
  testSpecId      BigInt           @map("test_spec_id")
  sectionId       BigInt?          @map("section_id")
  title           String           @db.VarChar(500)
  description     String?          @db.Text
  preconditions   String?          @db.Text
  expectedResult  String?          @map("expected_result") @db.Text
  checkpoint      String?          @db.Text
  scenario        String?          @db.Text
  testEnvironment String?          @map("test_environment") @db.Text
  notes           String?          @db.Text
  tags            String[]         @default([])
  classification  String?          @db.VarChar(100)
  referenceId     String?          @map("reference_id") @db.VarChar(100)
  estimatedTime   Int?             @map("estimated_time")
  priority        TestCasePriority @default(MEDIUM)
  testType        TestType         @default(FUNCTIONAL) @map("test_type")
  testTechnique   TestTechnique    @default(OTHER) @map("test_technique")
  isMatrix        Boolean          @default(false) @map("is_matrix")
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  testSpec  TestSpec     @relation(fields: [testSpecId], references: [id], onDelete: Cascade)
  section   TestSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  testSteps TestStep[]

  @@index([testSpecId])
  @@index([sectionId])
  @@index([priority])
  @@index([testType])
  @@index([sortOrder])
  @@index([classification])
  @@index([referenceId])
  @@map("test_cases")
}

/// テスト手順
model TestStep {
  id         BigInt   @id @default(autoincrement())
  testCaseId BigInt   @map("test_case_id")
  stepNo     Int      @map("step_no")
  actionMd   String   @map("action_md") @db.Text
  expectedMd String?  @map("expected_md") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, stepNo])
  @@index([testCaseId])
  @@index([stepNo])
  @@map("test_steps")
}
