  CRITICAL
  MAJOR
  MINOR
  TRIVIAL

  @@map("bug_severity_level")
}

/// バグ対策ナレッジ（バグ対策パターン・ノウハウ）
model BugCountermeasure {
  id                   BigInt                    @id @default(autoincrement())
  projectId            BigInt?                   @map("project_id")
  title                String                    @db.VarChar(255)
  description          String?                   @db.Text
  content              String                    @db.Text
  bugPattern           String                    @db.VarChar(100) @map("bug_pattern") // バグパターン名
  category             BugCountermeasureCategory @default(PREVENTION)
  status               BugCountermeasureStatus   @default(DRAFT)
  severityLevel        BugSeverityLevel?         @map("severity_level") // 対象バグの深刻度

  // Arrays stored as JSON
  rootCauses           Json                      @default("[]") @map("root_causes") @db.JsonB // string[] - 根本原因
  symptoms             Json                      @default("[]") @db.JsonB // string[] - 症状・兆候
  preventionMeasures   Json                      @default("[]") @map("prevention_measures") @db.JsonB // string[] - 予防策
  detectionMethods     Json                      @default("[]") @map("detection_methods") @db.JsonB // string[] - 検出方法
  correctionSteps      Json                      @default("[]") @map("correction_steps") @db.JsonB // string[] - 修正手順
  affectedAreas        Json                      @default("[]") @map("affected_areas") @db.JsonB // string[] - 影響範囲
  testCoverage         Json                      @default("[]") @map("test_coverage") @db.JsonB // string[] - テストカバレッジ
  examples             Json                      @default("[]") @db.JsonB // string[] - 事例
  references           Json                      @default("[]") @db.JsonB // string[] - 参考資料

  // Rating and usage
  rating               Decimal                   @default(0) @db.Decimal(3, 2)
  ratingCount          Int                       @default(0) @map("rating_count")
  usageCount           Int                       @default(0) @map("usage_count")
  lastUsedAt           DateTime?                 @map("last_used_at")

  // Metadata
  metadata             Json?                     @db.JsonB
  version              String                    @default("1.0.0") @db.VarChar(20)

  // Audit fields
  createdById          BigInt?                   @map("created_by_id")
  updatedById          BigInt?                   @map("updated_by_id")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  // Relations
  project              Project?                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy            User?                     @relation("BugCountermeasureCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?                     @relation("BugCountermeasureUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
