  feedbacks            BugCountermeasureFeedback[]

  @@unique([projectId, title])
  @@index([projectId])
  @@index([bugPattern])
  @@index([category])
  @@index([status])
  @@index([severityLevel])
  @@index([rating])
  @@index([createdById])
  @@map("bug_countermeasures")
}

