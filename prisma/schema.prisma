  type          CatalogItemType
  status        CatalogItemStatus @default(DRAFT)
  category      String?           @db.VarChar(100)
  content       String            @db.Text
  metadata      Json?             @db.JsonB
  version       String            @default("1.0.0") @db.VarChar(20)
