/// カタログアイテムタイプ
enum CatalogItemType {
  TEST_CASE          // テストケース
  TEST_PROCEDURE     // テスト手順
  TEST_DATA          // テストデータ
  PRECONDITION       // 前提条件
  EXPECTED_RESULT    // 期待結果
  SHARED_STEP        // 共有ステップ
  TEMPLATE           // テンプレート
  OTHER              // その他

  @@map("catalog_item_type")
