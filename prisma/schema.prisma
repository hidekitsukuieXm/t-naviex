// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ユーザー・権限系モデル
// ============================================

/// ユーザー
model User {
  id            BigInt     @id @default(autoincrement())
  email         String     @unique @db.VarChar(255)
  name          String     @db.VarChar(255)
  passwordHash  String?    @map("password_hash") @db.VarChar(255)
  emailVerified DateTime?  @map("email_verified")
  image         String?    @db.VarChar(500)
  status        UserStatus @default(ACTIVE)
  mfaEnabled    Boolean    @default(false) @map("mfa_enabled")
  mfaType       String?    @map("mfa_type") @db.VarChar(50)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relations
  accounts             Account[]
  sessions             Session[]
  userGroups           UserGroup[]
  projectMembers       ProjectMember[]
  auditLogs            AuditLog[]
  accountLockout       AccountLockout?
  passwordHistories    PasswordHistory[]
  assignedTasks        Task[]
  assignedTestRunCases TestRunCase[]
  executedTestResults  TestResult[]
  comments             Comment[]
  commentMentions      CommentMention[]

  @@map("users")
}

/// ユーザーステータス
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING

  @@map("user_status")
}

/// NextAuth Account（OAuth連携用）
model Account {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt   @map("user_id")
  type              String   @db.VarChar(255)
  provider          String   @db.VarChar(255)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?  @db.VarChar(255)
  scope             String?  @db.VarChar(255)
  id_token          String?  @db.Text
  session_state     String?  @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// NextAuth Session
model Session {
  id           BigInt   @id @default(autoincrement())
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       BigInt   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// NextAuth VerificationToken（メール認証用）
model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// パスワードリセットトークン
model PasswordResetToken {
  id        BigInt   @id @default(autoincrement())
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

/// グループ
model Group {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userGroups UserGroup[]

  @@map("groups")
}

/// ユーザーグループ中間テーブル
model UserGroup {
  userId    BigInt   @map("user_id")
  groupId   BigInt   @map("group_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_groups")
}

/// ロール（権限定義）
model Role {
  id           BigInt   @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  displayName  String   @map("display_name") @db.VarChar(100)
  description  String?  @db.VarChar(500)
  permissions  Json     @default("{}") @db.JsonB
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  projectMembers ProjectMember[]

  @@map("roles")
}

// ============================================
// プロジェクト系モデル
// ============================================

/// プロジェクト
model Project {
  id            BigInt        @id @default(autoincrement())
  name          String        @db.VarChar(255)
  description   String?       @db.Text
  status        ProjectStatus @default(ACTIVE)
  projectType   String?       @map("project_type") @db.VarChar(100)
  targetVersion String?       @map("target_version") @db.VarChar(100)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  projectMembers       ProjectMember[]
  testSpecs            TestSpec[]
  tags                 Tag[]
  testTypeMasters      TestTypeMaster[]
  testTechniqueMasters TestTechniqueMaster[]
  testPerspectives     TestPerspective[]
  testCaseTemplates    TestCaseTemplate[]
  sharedSteps          SharedStep[]
  milestones           Milestone[]
  configurations       Configuration[]
  tasks                Task[]
  testRuns             TestRun[]

  @@map("projects")
}

/// プロジェクトステータス
enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  PLANNING

  @@map("project_status")
}

/// プロジェクトメンバー中間テーブル
model ProjectMember {
  projectId BigInt   @map("project_id")
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([projectId, userId])
  @@map("project_members")
}

// ============================================
// 監査ログモデル
// ============================================

/// 監査ログ
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt?  @map("user_id")
  action     String   @db.VarChar(100)
  targetType String   @map("target_type") @db.VarChar(100)
  targetId   BigInt?  @map("target_id")
  details    Json?    @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// パスワードポリシー・セキュリティ系モデル
// ============================================

/// パスワードポリシー設定（シングルトン：1レコードのみ）
model PasswordPolicy {
  id                     BigInt   @id @default(autoincrement())
  minLength              Int      @default(8) @map("min_length")
  maxLength              Int      @default(100) @map("max_length")
  requireUppercase       Boolean  @default(true) @map("require_uppercase")
  requireLowercase       Boolean  @default(true) @map("require_lowercase")
  requireNumbers         Boolean  @default(true) @map("require_numbers")
  requireSpecialChars    Boolean  @default(false) @map("require_special_chars")
  expirationDays         Int      @default(0) @map("expiration_days")
  preventReuse           Int      @default(0) @map("prevent_reuse")
  maxLoginAttempts       Int      @default(5) @map("max_login_attempts")
  lockoutDurationMinutes Int      @default(30) @map("lockout_duration_minutes")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("password_policies")
}

/// アカウントロック情報
model AccountLockout {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @unique @map("user_id")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lastFailedAt   DateTime? @map("last_failed_at")
  lockedUntil    DateTime? @map("locked_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account_lockouts")
}

/// パスワード履歴（再利用防止用）
model PasswordHistory {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_histories")
}

/// セッション設定（シングルトン：1レコードのみ）
model SessionSettings {
  id                    BigInt   @id @default(autoincrement())
  sessionTimeoutMinutes Int      @default(30) @map("session_timeout_minutes")
  warningBeforeMinutes  Int      @default(5) @map("warning_before_minutes")
  extendOnActivity      Boolean  @default(true) @map("extend_on_activity")
  maxConcurrentSessions Int      @default(0) @map("max_concurrent_sessions")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("session_settings")
}

// ============================================
// テスト仕様書系モデル
// ============================================

/// テスト仕様書ステータス
enum TestSpecStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED

  @@map("test_spec_status")
}

/// テスト仕様書
model TestSpec {
  id          BigInt         @id @default(autoincrement())
  projectId   BigInt         @map("project_id")
  name        String         @db.VarChar(255)
  description String?        @db.Text
  status      TestSpecStatus @default(DRAFT)
  version     String         @default("1.0.0") @db.VarChar(50)
  isLocked    Boolean        @default(false) @map("is_locked")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions  TestSpecVersion[]
  sections  TestSection[]
  testCases TestCase[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("test_specs")
}

/// テスト仕様書バージョン履歴
model TestSpecVersion {
  id         BigInt   @id @default(autoincrement())
  testSpecId BigInt   @map("test_spec_id")
  version    String   @db.VarChar(50)
  changeNote String?  @map("change_note") @db.Text
  createdBy  BigInt?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  testSpec TestSpec @relation(fields: [testSpecId], references: [id], onDelete: Cascade)

  @@index([testSpecId])
  @@index([createdAt])
  @@map("test_spec_versions")
}

/// テストセクション（階層構造対応）
model TestSection {
  id         BigInt   @id @default(autoincrement())
  testSpecId BigInt   @map("test_spec_id")
  parentId   BigInt?  @map("parent_id")
  name       String   @db.VarChar(255)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  testSpec  TestSpec      @relation(fields: [testSpecId], references: [id], onDelete: Cascade)
  parent    TestSection?  @relation("SectionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  TestSection[] @relation("SectionHierarchy")
  testCases TestCase[]

  @@index([testSpecId])
  @@index([parentId])
  @@index([sortOrder])
  @@map("test_sections")
}

/// テストケース優先度
enum TestCasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW

  @@map("test_case_priority")
}

/// テストタイプ
enum TestType {
  FUNCTIONAL
  INTEGRATION
  E2E
  PERFORMANCE
  SECURITY
  USABILITY
  OTHER

  @@map("test_type")
}

/// テスト技法
enum TestTechnique {
  EQUIVALENCE_PARTITIONING
  BOUNDARY_VALUE_ANALYSIS
  DECISION_TABLE
  STATE_TRANSITION
  EXPLORATORY
  REGRESSION
  OTHER

  @@map("test_technique")
}

/// テストケース
model TestCase {
  id              BigInt           @id @default(autoincrement())
  testSpecId      BigInt           @map("test_spec_id")
  sectionId       BigInt?          @map("section_id")
  title           String           @db.VarChar(500)
  description     String?          @db.Text
  preconditions   String?          @db.Text
  expectedResult  String?          @map("expected_result") @db.Text
  checkpoint      String?          @db.Text
  scenario        String?          @db.Text
  testEnvironment String?          @map("test_environment") @db.Text
  notes           String?          @db.Text
  tags            String[]         @default([])
  classification  String?          @db.VarChar(100)
  referenceId     String?          @map("reference_id") @db.VarChar(100)
  estimatedTime   Int?             @map("estimated_time")
  priority        TestCasePriority @default(MEDIUM)
  testType        TestType         @default(FUNCTIONAL) @map("test_type")
  testTechnique   TestTechnique    @default(OTHER) @map("test_technique")
  isMatrix        Boolean          @default(false) @map("is_matrix")
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  // Relations
  testSpec     TestSpec      @relation(fields: [testSpecId], references: [id], onDelete: Cascade)
  section      TestSection?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  testSteps    TestStep[]
  testCaseTags TestCaseTag[]
  testRunCases TestRunCase[]
  dependencies CaseDependency[] @relation("TestCaseDependencies")
  dependents   CaseDependency[] @relation("DependsOnTestCase")

  @@index([testSpecId])
  @@index([sectionId])
  @@index([priority])
  @@index([testType])
  @@index([sortOrder])
  @@index([classification])
  @@index([referenceId])
  @@index([deletedAt])
  @@map("test_cases")
}

/// テスト手順
model TestStep {
  id           BigInt   @id @default(autoincrement())
  testCaseId   BigInt   @map("test_case_id")
  stepNo       Int      @map("step_no")
  actionMd     String   @map("action_md") @db.Text
  expectedMd   String?  @map("expected_md") @db.Text
  sharedStepId BigInt?  @map("shared_step_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  testCase   TestCase    @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  sharedStep SharedStep? @relation(fields: [sharedStepId], references: [id], onDelete: SetNull)

  @@unique([testCaseId, stepNo])
  @@index([testCaseId])
  @@index([stepNo])
  @@index([sharedStepId])
  @@map("test_steps")
}

/// テストケース依存関係タイプ
enum CaseDependencyType {
  BLOCKS    // このケースが完了するまで依存ケースはブロックされる
  REQUIRES  // 依存ケースが合格である必要がある
  RELATED   // 関連があるが実行順序には影響しない
}

/// テストケース依存関係
model CaseDependency {
  id             BigInt             @id @default(autoincrement())
  testCaseId     BigInt             @map("test_case_id")
  dependsOnId    BigInt             @map("depends_on_id")
  dependencyType CaseDependencyType @default(REQUIRES) @map("dependency_type")
  description    String?            @db.VarChar(500)
  createdAt      DateTime           @default(now()) @map("created_at")

  // Relations
  testCase  TestCase @relation("TestCaseDependencies", fields: [testCaseId], references: [id], onDelete: Cascade)
  dependsOn TestCase @relation("DependsOnTestCase", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, dependsOnId])
  @@index([testCaseId])
  @@index([dependsOnId])
  @@index([dependencyType])
  @@map("case_dependencies")
}

// ============================================
// タグ管理モデル
// ============================================

/// タグ
model Tag {
  id          BigInt   @id @default(autoincrement())
  projectId   BigInt   @map("project_id")
  name        String   @db.VarChar(100)
  color       String   @default("#3b82f6") @db.VarChar(7)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCaseTags TestCaseTag[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([name])
  @@map("tags")
}

/// テストケースタグ中間テーブル
model TestCaseTag {
  testCaseId BigInt   @map("test_case_id")
  tagId      BigInt   @map("tag_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([testCaseId, tagId])
  @@index([testCaseId])
  @@index([tagId])
  @@map("test_case_tags")
}

// ============================================
// テストタイプ・技法・観点マスタ
// ============================================

/// テストタイプマスタ
model TestTypeMaster {
  id          BigInt   @id @default(autoincrement())
  projectId   BigInt   @map("project_id")
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([projectId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("test_type_masters")
}

/// テスト技法マスタ
model TestTechniqueMaster {
  id          BigInt   @id @default(autoincrement())
  projectId   BigInt   @map("project_id")
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([projectId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("test_technique_masters")
}

/// テスト観点マスタ
model TestPerspective {
  id          BigInt   @id @default(autoincrement())
  projectId   BigInt   @map("project_id")
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([projectId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("test_perspectives")
}

// ============================================
// テストケーステンプレート
// ============================================

/// テストケーステンプレート
model TestCaseTemplate {
  id                  BigInt           @id @default(autoincrement())
  projectId           BigInt           @map("project_id")
  name                String           @db.VarChar(255)
  description         String?          @db.Text
  title               String?          @db.VarChar(500)
  templateDescription String?          @map("template_description") @db.Text
  preconditions       String?          @db.Text
  expectedResult      String?          @map("expected_result") @db.Text
  checkpoint          String?          @db.Text
  scenario            String?          @db.Text
  testEnvironment     String?          @map("test_environment") @db.Text
  notes               String?          @db.Text
  tags                String[]         @default([])
  classification      String?          @db.VarChar(100)
  priority            TestCasePriority @default(MEDIUM)
  testType            TestType         @default(FUNCTIONAL) @map("test_type")
  testTechnique       TestTechnique    @default(OTHER) @map("test_technique")
  isDefault           Boolean          @default(false) @map("is_default")
  sortOrder           Int              @default(0) @map("sort_order")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  // Relations
  project       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateSteps TestCaseTemplateStep[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([sortOrder])
  @@index([isDefault])
  @@map("test_case_templates")
}

/// テストケーステンプレートのテスト手順
model TestCaseTemplateStep {
  id         BigInt   @id @default(autoincrement())
  templateId BigInt   @map("template_id")
  stepNo     Int      @map("step_no")
  actionMd   String   @map("action_md") @db.Text
  expectedMd String?  @map("expected_md") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  template TestCaseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, stepNo])
  @@index([templateId])
  @@index([stepNo])
  @@map("test_case_template_steps")
}

// ============================================
// 共有テスト手順
// ============================================

/// 共有テスト手順
model SharedStep {
  id          BigInt   @id @default(autoincrement())
  projectId   BigInt   @map("project_id")
  name        String   @db.VarChar(255)
  description String?  @db.Text
  contentMd   String   @map("content_md") @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testSteps TestStep[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([sortOrder])
  @@map("shared_steps")
}

// ============================================
// マイルストーン・コンフィギュレーション（Phase 2: テスト実施・結果管理）
// ============================================

/// マイルストーンステータス
enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("milestone_status")
}

/// マイルストーン
model Milestone {
  id          BigInt          @id @default(autoincrement())
  projectId   BigInt          @map("project_id")
  name        String          @db.VarChar(255)
  description String?         @db.Text
  status      MilestoneStatus @default(PLANNED)
  startDate   DateTime?       @map("start_date") @db.Date
  dueDate     DateTime?       @map("due_date") @db.Date
  completedAt DateTime?       @map("completed_at")
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testRuns TestRun[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([sortOrder])
  @@map("milestones")
}

/// コンフィギュレーション（テスト環境設定）
model Configuration {
  id           BigInt   @id @default(autoincrement())
  projectId    BigInt   @map("project_id")
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  configParams Json     @default("{}") @map("config_params") @db.JsonB
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testRuns TestRun[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("configurations")
}

/// タスクステータス
enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED

  @@map("task_status")
}

/// タスク優先度
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("task_priority")
}

/// タスク（親子関係対応）
model Task {
  id          BigInt       @id @default(autoincrement())
  projectId   BigInt       @map("project_id")
  parentId    BigInt?      @map("parent_task_id")
  title       String       @db.VarChar(500)
  description String?      @db.Text
  status      TaskStatus   @default(NOT_STARTED)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  BigInt?      @map("assignee_id")
  startDate   DateTime?    @map("start_date") @db.Date
  endDate     DateTime?    @map("end_date") @db.Date
  progress    Int          @default(0)
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   Task?   @relation("TaskParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children Task[]  @relation("TaskParentChild")
  assignee User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([parentId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([startDate])
  @@index([endDate])
  @@index([sortOrder])
  @@map("tasks")
}

// ============================================
// テストラン（テスト実行管理）
// ============================================

/// テストランステータス
enum TestRunStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ABORTED
  BLOCKED

  @@map("test_run_status")
}

/// テストラン
model TestRun {
  id              BigInt        @id @default(autoincrement())
  projectId       BigInt        @map("project_id")
  milestoneId     BigInt?       @map("milestone_id")
  configurationId BigInt?       @map("configuration_id")
  name            String        @db.VarChar(255)
  description     String?       @db.Text
  status          TestRunStatus @default(PLANNED)
  plannedStartDate DateTime?    @map("planned_start_date") @db.Date
  plannedEndDate   DateTime?    @map("planned_end_date") @db.Date
  actualStartDate  DateTime?    @map("actual_start_date") @db.Date
  actualEndDate    DateTime?    @map("actual_end_date") @db.Date
  totalCases       Int          @default(0) @map("total_cases")
  passedCases      Int          @default(0) @map("passed_cases")
  failedCases      Int          @default(0) @map("failed_cases")
  blockedCases     Int          @default(0) @map("blocked_cases")
  skippedCases     Int          @default(0) @map("skipped_cases")
  notes            String?      @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone     Milestone?     @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  configuration Configuration? @relation(fields: [configurationId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([milestoneId])
  @@index([configurationId])
  @@index([status])
  @@index([plannedStartDate])
  @@index([plannedEndDate])
  @@index([createdAt])
  @@map("test_runs")

  // Relations (added)
  testRunCases TestRunCase[]
}

/// テストランケースステータス
enum TestRunCaseStatus {
  NOT_RUN
  PASSED
  FAILED
  BLOCKED
  SKIPPED
  RETEST

  @@map("test_run_case_status")
}

/// テストランケース（テストランとテストケースの紐付け）
model TestRunCase {
  id              BigInt            @id @default(autoincrement())
  testRunId       BigInt            @map("test_run_id")
  testCaseId      BigInt            @map("test_case_id")
  assignedToId    BigInt?           @map("assigned_to_id")
  status          TestRunCaseStatus @default(NOT_RUN)
  executedAt      DateTime?         @map("executed_at")
  executionTime   Int?              @map("execution_time")
  actualResult    String?           @map("actual_result") @db.Text
  defects         String?           @db.Text
  comment         String?           @db.Text
  reproducibility String?           @db.VarChar(50)
  sortOrder       Int               @default(0) @map("sort_order")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  testRun    TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCase   TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@unique([testRunId, testCaseId])
  @@index([testRunId])
  @@index([testCaseId])
  @@index([assignedToId])
  @@index([status])
  @@index([executedAt])
  @@index([sortOrder])
  @@map("test_run_cases")

  // Relations for test results history
  testResults TestResult[]
}

/// テスト結果（実行履歴）
model TestResult {
  id              BigInt            @id @default(autoincrement())
  testRunCaseId   BigInt            @map("test_run_case_id")
  executedById    BigInt?           @map("executed_by_id")
  status          TestRunCaseStatus
  executedAt      DateTime          @default(now()) @map("executed_at")
  executionTime   Int?              @map("execution_time")
  actualResult    String?           @map("actual_result") @db.Text
  defects         String?           @db.Text
  comment         String?           @db.Text
  reproducibility String?           @db.VarChar(50)
  environment     String?           @db.VarChar(255)
  browserInfo     String?           @map("browser_info") @db.VarChar(255)
  version         Int               @default(1)
  createdAt       DateTime          @default(now()) @map("created_at")

  // Relations
  testRunCase TestRunCase            @relation(fields: [testRunCaseId], references: [id], onDelete: Cascade)
  executedBy  User?                  @relation(fields: [executedById], references: [id], onDelete: SetNull)
  attachments TestResultAttachment[]

  @@index([testRunCaseId])
  @@index([executedById])
  @@index([status])
  @@index([executedAt])
  @@index([version])
  @@map("test_results")
}

/// テスト結果添付ファイル
model TestResultAttachment {
  id           BigInt   @id @default(autoincrement())
  testResultId BigInt   @map("test_result_id")
  fileName     String   @map("file_name") @db.VarChar(255)
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type") @db.VarChar(100)
  storagePath  String   @map("storage_path") @db.VarChar(500)
  thumbnailPath String? @map("thumbnail_path") @db.VarChar(500)
  description  String?  @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  testResult TestResult @relation(fields: [testResultId], references: [id], onDelete: Cascade)

  @@index([testResultId])
  @@index([createdAt])
  @@map("test_result_attachments")
}

// ============================================
// コメント・Q&A機能
// ============================================

/// コメント対象エンティティタイプ
enum CommentTargetType {
  TEST_RUN_CASE
  TEST_RESULT
  TEST_CASE
  TEST_SPEC

  @@map("comment_target_type")
}

/// コメント
model Comment {
  id            BigInt            @id @default(autoincrement())
  targetType    CommentTargetType @map("target_type")
  targetId      BigInt            @map("target_id")
  parentId      BigInt?           @map("parent_id")
  authorId      BigInt            @map("author_id")
  content       String            @db.Text
  isEdited      Boolean           @default(false) @map("is_edited")
  isResolved    Boolean           @default(false) @map("is_resolved")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  deletedAt     DateTime?         @map("deleted_at")

  // Relations
  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment?   @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]  @relation("CommentThread")
  mentions CommentMention[]

  @@index([targetType, targetId])
  @@index([parentId])
  @@index([authorId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("comments")
}

/// コメントメンション
model CommentMention {
  id          BigInt   @id @default(autoincrement())
  commentId   BigInt   @map("comment_id")
  userId      BigInt   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_mentions")
}
