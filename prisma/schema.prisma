  // Relations
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([catalogItemId, tagId])
  @@index([catalogItemId])
  @@index([tagId])
  @@map("catalog_item_tags")
}

/// テストセットステータス
enum TestSetStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

/// テストセット
model TestSet {
