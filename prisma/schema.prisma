/// ベースラインステータス
enum BaselineStatus {
  DRAFT
  APPROVED
  LOCKED
  ARCHIVED
}

/// ベースライン（テスト仕様書のスナップショット）
model Baseline {
  id          BigInt         @id @default(autoincrement())
  testSpecId  BigInt         @map("test_spec_id")
  name        String         @db.VarChar(255)
  description String?        @db.Text
  version     String         @db.VarChar(50)
  status      BaselineStatus @default(DRAFT)
  snapshotAt  DateTime       @default(now()) @map("snapshot_at")
  metadata    Json?          @db.JsonB

  // Statistics at snapshot time
  totalCases  Int @default(0) @map("total_cases")
  totalSteps  Int @default(0) @map("total_steps")

  // Audit fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById BigInt    @map("created_by_id")
  approvedAt  DateTime? @map("approved_at")
  approvedById BigInt?  @map("approved_by_id")

  // Relations
  testSpec    TestSpec       @relation(fields: [testSpecId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("BaselineCreatedBy", fields: [createdById], references: [id])
  approvedBy  User?          @relation("BaselineApprovedBy", fields: [approvedById], references: [id])
  items       BaselineItem[]

